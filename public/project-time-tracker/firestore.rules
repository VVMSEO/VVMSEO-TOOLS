rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: categories
    // Document ID: {categoryId}
    // Fields:
    //   - userId: string (required, immutable)
    //   - name: string (required, length 1-100)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - userId: string (required, immutable)
    //   - name: string (required, length 1-100)
    //   - weeklyBudget: number (optional, >= 0)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: tasks
    // Document ID: {taskId}
    // Fields:
    //   - userId: string (required, immutable)
    //   - projectId: string (optional)
    //   - projectName: string (optional, legacy)
    //   - taskName: string (required, length 1-200)
    //   - plannedTime: number (required, >= 0)
    //   - actualTime: number (required, >= 0)
    //   - executionDate: string (optional, YYYY-MM-DD)
    //   - createdAt: timestamp (required, immutable)
    //   - categoryId: string (optional)
    //   - isRunning: boolean (optional)
    //   - timerStartedAt: timestamp | null (optional)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isPositiveOrZero(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidCategory(data) {
      return hasOnlyAllowedFields(['userId', 'name', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             data.createdAt is timestamp;
    }

    match /categories/{categoryId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['userId', 'name', 'createdAt']) && 
                    isValidCategory(request.resource.data) && 
                    uidUnchanged();
      allow update: if isDocOwner() && 
                    isValidCategory(request.resource.data) && 
                    uidNotModified() && 
                    areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isDocOwner();
    }

    function isValidProject(data) {
      return hasOnlyAllowedFields(['userId', 'name', 'weeklyBudget', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             (!('weeklyBudget' in data) || (data.weeklyBudget is number && data.weeklyBudget >= 0)) &&
             data.createdAt is timestamp;
    }

    match /projects/{projectId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['userId', 'name', 'createdAt']) && 
                    isValidProject(request.resource.data) && 
                    uidUnchanged();
      allow update: if isDocOwner() && 
                    isValidProject(request.resource.data) && 
                    uidNotModified() && 
                    areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isDocOwner();
    }

    function isValidTask(data) {
      return hasOnlyAllowedFields(['userId', 'projectId', 'projectName', 'taskName', 'plannedTime', 'actualTime', 'executionDate', 'createdAt', 'categoryId', 'isRunning', 'timerStartedAt']) &&
             (!('projectName' in data) || validStringLength('projectName', 1, 100)) &&
             (!('projectId' in data) || data.projectId is string) &&
             validStringLength('taskName', 1, 200) &&
             isPositiveOrZero('plannedTime') &&
             isPositiveOrZero('actualTime') &&
             (!('executionDate' in data) || (data.executionDate is string && data.executionDate.matches('^\\d{4}-\\d{2}-\\d{2}$'))) &&
             data.createdAt is timestamp &&
             (!('categoryId' in data) || data.categoryId is string) &&
             (!('isRunning' in data) || data.isRunning is bool) &&
             (!('timerStartedAt' in data) || data.timerStartedAt is timestamp);
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['userId', 'taskName', 'plannedTime', 'actualTime', 'createdAt']) &&
                    isValidTask(request.resource.data) && 
                    uidUnchanged();
      allow update: if isDocOwner() && 
                    isValidTask(request.resource.data) && 
                    uidNotModified() &&
                    areImmutableFieldsUnchanged(['createdAt', 'userId']);
      allow delete: if isDocOwner();
    }
  }
}
