{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "A category that can be assigned to tasks.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this category."
        },
        "name": {
          "type": "string",
          "description": "The name of the category."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the category was created."
        }
      },
      "required": ["userId", "name", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A project that tasks belong to.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this project."
        },
        "name": {
          "type": "string",
          "description": "The name of the project."
        },
        "weeklyBudget": {
          "type": "number",
          "description": "The weekly budget for the project in minutes."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the project was created."
        }
      },
      "required": ["userId", "name", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A task within a project with planned and actual time.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this task."
        },
        "projectId": {
          "type": "string",
          "description": "The ID of the project."
        },
        "projectName": {
          "type": "string",
          "description": "The name of the project (legacy)."
        },
        "taskName": {
          "type": "string",
          "description": "The name of the task."
        },
        "plannedTime": {
          "type": "number",
          "description": "Planned time in minutes."
        },
        "actualTime": {
          "type": "number",
          "description": "Actual time spent in minutes."
        },
        "executionDate": {
          "type": "string",
          "description": "Date of execution in YYYY-MM-DD format."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the task was created."
        },
        "categoryId": {
          "type": "string",
          "description": "Optional category ID."
        },
        "isRunning": {
          "type": "boolean",
          "description": "Whether the timer is currently running."
        },
        "timerStartedAt": {
          "type": "timestamp",
          "description": "When the timer was last started."
        }
      },
      "required": ["userId", "taskName", "plannedTime", "actualTime", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": {
        "$ref": "#/entities/Project"
      },
      "description": "Stores all projects for all users."
    },
    "/tasks/{taskId}": {
      "schema": {
        "$ref": "#/entities/Task"
      },
      "description": "Stores all tasks for all users."
    },
    "/categories/{categoryId}": {
      "schema": {
        "$ref": "#/entities/Category"
      },
      "description": "Stores all categories for all users."
    }
  }
}
